PORT=3000
NODE_ENV=production

# ============================
# HuggingFace (BẮT BUỘC cho video)
# Đăng ký miễn phí tại: https://huggingface.co/settings/tokens
# ============================
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ============================
# ComfyUI (TÙY CHỌN - nếu bạn tự host ComfyUI)
# Mặc định: http://127.0.0.1:8188
# ============================
COMFYUI_URL=http://your-comfyui-server:8188
